{
  "scenarios": [
    {
      "id": "classify-trivial-routing",
      "group": "dev",
      "description": "A clearly bounded bug fix routes as trivial and skips grilling.",
      "mode": "forced",
      "prompt": "Use classify for this: fix a typo in an error message in one file.",
      "expected_output_contains": "classification: trivial",
      "pass_criteria": "Response contains 'classification: trivial' and does not mention grill-with-docs or PRD"
    },
    {
      "id": "classify-major-routing",
      "group": "dev",
      "description": "A request touching public API routes as major and enters grill-with-docs.",
      "mode": "forced",
      "prompt": "Use classify for this: add a new authentication flow with a new database table.",
      "expected_output_contains": "classification: major",
      "pass_criteria": "Response contains 'classification: major' and rationale mentions public contract or migrations"
    },
    {
      "id": "ask-kh-instruction-doc-routes-to-skill-review",
      "group": "dev",
      "description": "A request to change a SKILL.md routes to SKILL_REVIEW not the code pipeline.",
      "mode": "forced",
      "prompt": "Use ask-kh for this: improve the grilling skill to ask better questions.",
      "expected_output_contains": "SKILL_REVIEW",
      "pass_criteria": "Response routes to loops/SKILL_REVIEW.md, not to classify or grill-with-docs"
    },
    {
      "id": "ask-kh-resume-state-file",
      "group": "dev",
      "description": "ask-kh checks for .killhouse/run-state.json on startup.",
      "mode": "static",
      "checks": [
        {
          "type": "contains",
          "path": "skills/ask-kh/SKILL.md",
          "text": ".killhouse/run-state.json"
        },
        {
          "type": "contains",
          "path": ".gitignore",
          "text": "run-state.json"
        }
      ]
    },
    {
      "id": "autopilot-budget-guard-fields",
      "group": "dev",
      "description": "Budget guard fields are documented with defaults.",
      "mode": "static",
      "checks": [
        {
          "type": "contains",
          "path": "skills/ask-kh/references/autonomy.md",
          "text": "max_milestones_unattended"
        },
        {
          "type": "contains",
          "path": "skills/ask-kh/references/autonomy.md",
          "text": "max_pipeline_reentries"
        },
        {
          "type": "contains",
          "path": "skills/ask-kh/references/autonomy.md",
          "text": "degrade to Checkpoint mode and ask"
        }
      ]
    },
    {
      "id": "mandatory-gate-not-skippable",
      "group": "held_out",
      "description": "Mandatory gates halt in Autopilot; Autopilot only skips courtesy checkpoints.",
      "mode": "static",
      "checks": [
        {
          "type": "contains",
          "path": "skills/ask-kh/SKILL.md",
          "text": "Mandatory gates (never skipped, in either mode)"
        },
        {
          "type": "contains",
          "path": "skills/ask-kh/references/autonomy.md",
          "text": "Hard blocker"
        }
      ]
    },
    {
      "id": "skill-review-directly-invocable",
      "group": "dev",
      "description": "SKILL_REVIEW is registered as a slash command and documented for direct invocation.",
      "mode": "static",
      "checks": [
        {
          "type": "contains",
          "path": ".claude-plugin/plugin.json",
          "text": "skill-review"
        },
        {
          "type": "contains",
          "path": "skills/skill-review/SKILL.md",
          "text": "loops/SKILL_REVIEW.md"
        }
      ]
    },
    {
      "id": "claude-ask-kh-starts-at-classify",
      "group": "dev",
      "description": "Claude Code users keep slash-command entrypoints and ask-kh routes through classify for conversation requests.",
      "checks": [
        {
          "type": "contains",
          "path": "README.md",
          "text": "> /ask-kh I want to build a new feature."
        },
        {
          "type": "contains",
          "path": "skills/ask-kh/SKILL.md",
          "text": "/classify"
        }
      ]
    },
    {
      "id": "codex-ask-kh-skill-name",
      "group": "dev",
      "description": "Codex users invoke ask-kh by skill name and get a concrete marketplace setup path.",
      "checks": [
        {
          "type": "contains",
          "path": "README.md",
          "text": "Use ask-kh for this feature"
        },
        {
          "type": "contains",
          "path": "README.md",
          "text": "codex plugin marketplace add ."
        }
      ]
    },
    {
      "id": "instruction-documents-route-to-skill-review",
      "group": "dev",
      "description": "Instruction-document changes are routed to SKILL_REVIEW instead of ordinary code execution.",
      "checks": [
        {
          "type": "contains",
          "path": "AGENTS.md",
          "text": "loops/SKILL_REVIEW.md"
        },
        {
          "type": "contains",
          "path": "skills/ask-kh/SKILL.md",
          "text": "Instruction-document changes"
        }
      ]
    },
    {
      "id": "review-document-has-lean-verdict-handoff",
      "group": "dev",
      "description": "Spec audit returns an artifact/verdict handoff without transcript bloat.",
      "checks": [
        {
          "type": "contains",
          "path": "loops/REVIEW_DOCUMENT.md",
          "text": "verdict: CONVERGED | OPEN_QUESTIONS | MAX_ROUNDS | BLOCKED"
        },
        {
          "type": "contains",
          "path": "loops/REVIEW_DOCUMENT.md",
          "text": "Never return reviewer transcripts or raw round output"
        }
      ]
    },
    {
      "id": "execution-policy-cost-vs-time",
      "group": "dev",
      "description": "The pipeline exposes cost_optimized and time_optimized as execution routes with the same quality gates.",
      "checks": [
        {
          "type": "contains",
          "path": "skills/ask-kh/SKILL.md",
          "text": "Execution policy"
        },
        {
          "type": "contains",
          "path": "loops/PLAN.md",
          "text": "Quality is fixed by gates, review, and mandatory halts"
        },
        {
          "type": "contains",
          "path": "loops/IMPLEMENT_MILESTONE.md",
          "text": "Execution policy controls tier, not quality"
        }
      ]
    },
    {
      "id": "strict-optional-model-tier-map",
      "group": "dev",
      "description": "Model tier config is optional, exact, and echoed before use.",
      "checks": [
        {
          "type": "contains",
          "path": "AGENTS.md",
          "text": "A model tier map is\noptional"
        },
        {
          "type": "contains",
          "path": "skills/ask-kh/SKILL.md",
          "text": "Do not alias, normalize,\nupgrade, downgrade, or substitute model names"
        },
        {
          "type": "contains",
          "path": "skills/ask-kh/SKILL.md",
          "text": "If a config exists but is invalid"
        },
        {
          "type": "contains",
          "path": "loops/PLAN.md",
          "text": "MODEL_TIER_MAP"
        },
        {
          "type": "contains",
          "path": ".killhouse/config.example.json",
          "text": "proxy/exact-reasoning-model-id"
        }
      ]
    },
    {
      "id": "reasoning-contracts-cheap-models-code",
      "group": "dev",
      "description": "Reasoning-tier agents write contracts and review feedback by default while cheaper tiers do first-pass code.",
      "checks": [
        {
          "type": "contains",
          "path": "AGENTS.md",
          "text": "standard-tier agents handle routine contract review"
        },
        {
          "type": "contains",
          "path": "loops/PLAN.md",
          "text": "### 3.3 Implementation Authority"
        },
        {
          "type": "contains",
          "path": "loops/PLAN.md",
          "text": "implementation_contracts"
        },
        {
          "type": "contains",
          "path": "loops/PLAN.md",
          "text": "**light**: file contracts are optional"
        },
        {
          "type": "contains",
          "path": "loops/PLAN.md",
          "text": "contract_depth"
        },
        {
          "type": "contains",
          "path": "loops/PLAN.md",
          "text": "Routine contract checks default to `standard` tier"
        },
        {
          "type": "contains",
          "path": "loops/IMPLEMENT_MILESTONE.md",
          "text": "Contract Reviewer"
        },
        {
          "type": "contains",
          "path": "loops/IMPLEMENT_MILESTONE.md",
          "text": "Private helpers are allowed\n  inside an already-contracted file's responsibility"
        },
        {
          "type": "contains",
          "path": "loops/IMPLEMENT_MILESTONE.md",
          "text": "No `implementation_contracts`"
        },
        {
          "type": "contains",
          "path": "loops/IMPLEMENT_MILESTONE.md",
          "text": "promote `none_trivial` or `batch_standard`"
        },
        {
          "type": "contains",
          "path": "loops/IMPLEMENT_MILESTONE.md",
          "text": "economics ledger"
        },
        {
          "type": "contains",
          "path": "loops/IMPLEMENT_MILESTONE.md",
          "text": "Escalate before reasoning rewrite"
        }
      ]
    },
    {
      "id": "to-prd-does-not-mutate-tracker",
      "group": "held_out",
      "description": "PRD synthesis records gaps instead of interviewing or publishing to a tracker.",
      "checks": [
        {
          "type": "contains",
          "path": "skills/to-prd/SKILL.md",
          "text": "Do not check with the user during this skill"
        },
        {
          "type": "not_contains",
          "path": "skills/to-prd/SKILL.md",
          "text": "publish it to the project issue tracker"
        }
      ]
    },
    {
      "id": "child-skill-handoffs-have-file-fallbacks",
      "group": "held_out",
      "description": "Child skill handoffs preserve Claude slash commands and add Codex/generic fallbacks.",
      "checks": [
        {
          "type": "contains",
          "path": "skills/grill-with-docs/SKILL.md",
          "text": "skills/grilling/SKILL.md"
        },
        {
          "type": "contains",
          "path": "skills/triage/SKILL.md",
          "text": "skills/grill-with-docs/SKILL.md"
        }
      ]
    }
  ]
}
